{
	"name": "oceancodex/wpsp",
	"version": "13.0.0",
	"description": "WordPress Starter Plugin",
	"keywords": [
		"wordpress plugin",
		"wordpress starter plugin",
		"starter plugin",
		"starter",
		"wordpress",
		"plugin",
		"oceancodex",
		"wpsp",
		"wordpress framework",
		"wordpress plugin framework"
	],
	"license": "GPL-2.0-or-later",
	"require": {
		"php": "^8.3",
		"ext-intl": "*",
		"ext-json": "*",
		"ext-mbstring": "*",
		"ext-pdo": "*",
		"ext-readline": "*",
		"oceancodex/wpsp-core": "^13.0"
	},
	"require-dev": {
		"fakerphp/faker": "^v1.24",
		"laravel/pail": "^v1.2",
		"laravel/pao": "^1.0",
		"laravel/pint": "^v1.29",
		"mockery/mockery": "^1.6",
		"nunomaduro/collision": "^v8.9",
		"phpunit/phpunit": "^12.5"
	},
	"autoload": {
		"psr-4": {
			"WPSP\\": "",
			"WPSP\\App\\": "app/",
			"WPSP\\Database\\Factories\\": "database/factories/",
			"WPSP\\Database\\Migrations\\": "database/migrations/",
			"WPSP\\Database\\Seeders\\": "database/seeders/"
		},
		"files": [
			"app/Helpers/Helpers.php"
		],
		"exclude-from-classmap": [
			"node_modules/"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"WPSP\\Tests\\": "tests/"
		}
	},
	"authors": [
		{
			"name": "OceanCodex",
			"email": "contact@oceancodex.com"
		}
	],
	"scripts": {
		"dev": [],
		"test": [],
		"setup": [],
		"post-install-cmd": [
			"@php -r \"@unlink('bootstrap/cache/services.php'); @unlink('bootstrap/cache/packages.php');\""
		],
		"post-update-cmd": [
			"@php -r \"@unlink('bootstrap/cache/services.php'); @unlink('bootstrap/cache/packages.php');\""
		],
		"post-autoload-dump": [],
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],
		"post-create-project-cmd": [
			"@php artisan key:generate --ansi",
			"@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\""
		],
		"pre-package-uninstall": []
	},
	"config": {
		"sort-packages": true,
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true
		},
		"autoloader-suffix": "_wpsp_1719507007"
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
