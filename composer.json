{
	"name": "oceancodex/wpsp",
	"version": "13.1.26",
	"description": "WPSP Framework - WordPress Starter Plugin",
	"keywords": [
		"wordpress plugin",
		"wordpress starter plugin",
		"starter plugin",
		"starter",
		"wordpress",
		"plugin",
		"oceancodex",
		"wpsp",
		"wordpress framework",
		"wordpress plugin framework"
	],
	"license": "GPL-2.0-or-later",
	"require": {
		"php": "^8.3",
		"ext-intl": "*",
		"ext-json": "*",
		"ext-mbstring": "*",
		"ext-pdo": "*",
		"ext-readline": "*",
		"laravel/sanctum": "^4.0",
		"oceancodex/wpsp-core": "^13.0",
		"spatie/laravel-activitylog": "^4.12",
		"spatie/laravel-permission": "^7.3"
	},
	"require-dev": {
		"fakerphp/faker": "^v1.24",
		"fruitcake/laravel-debugbar": "^4.3",
		"laravel/pail": "^v1.2",
		"laravel/pao": "^1.0",
		"laravel/pint": "^v1.29",
		"mockery/mockery": "^1.6",
		"nunomaduro/collision": "^v8.9",
		"phpunit/phpunit": "^12.5"
	},
	"repositories": [
		{
			"url": "../wpsp-core",
			"type": "path",
			"options": {
				"symlink": true
			}
		}
	],
	"autoload": {
		"psr-4": {
			"WPSP\\": "",
			"WPSP\\App\\": "app/",
			"WPSP\\Database\\Factories\\": "database/factories/",
			"WPSP\\Database\\Migrations\\": "database/migrations/",
			"WPSP\\Database\\Seeders\\": "database/seeders/"
		},
		"files": [
			"app/Helpers/Helpers.php"
		],
		"exclude-from-classmap": [
			"node_modules/"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"WPSP\\Tests\\": "tests/"
		}
	},
	"authors": [
		{
			"name": "OceanCodex",
			"email": "contact@oceancodex.com"
		}
	],
	"scripts": {
		"setup": [],
		"dev": [
			"Composer\\Config::disableProcessTimeout",
			"npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
		],
		"test": [
			"@php artisan config:clear --ansi @no_additional_args",
			"@php artisan test"
		],
		"post-install-cmd": [
			"@php -r \"@unlink('bootstrap/cache/services.php'); @unlink('bootstrap/cache/packages.php');\""
		],
		"post-update-cmd": [
			"@php -r \"@unlink('bootstrap/cache/services.php'); @unlink('bootstrap/cache/packages.php');\""
		],
		"post-autoload-dump": [
			"@php artisan package:discover --ansi"
		],
		"post-root-package-install": [],
		"post-create-project-cmd": [
			"@php artisan key:generate --ansi",
			"@php -r \"file_exists('database/database.sqlite') || @touch('database/database.sqlite');\"",
			"@php artisan migrate --graceful --ansi"
		],
		"pre-package-uninstall": []
	},
	"config": {
		"sort-packages": true,
		"optimize-autoloader": true,
		"apcu-autoloader": true,
		"preferred-install": "dist",
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true
		},
		"autoloader-suffix": "_wpsp_1719507007"
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
