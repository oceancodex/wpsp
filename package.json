{
	"name": "wpsp",
	"version": "13.0.0",
	"description": "",
	"author": "OceanCodex",
	"license": "GPL-2.0-or-later",
	"main": "index.js",
	"directories": {
		"test": "tests"
	},
	"$schema": "https://www.schemastore.org/package.json",
	"private": true,
	"type": "module",
	"scripts": {
		"vite-dev": "npm run vue-dev",
		"vite-build": "vite build --config vite.config.mjs",
		"vite-watch": "vite build --watch --config vite.config.mjs",
		"vite-preview": "vite preview --config vite.config.mjs",

		"vue-dev": "vite --config vite.config.js",
		"vue-build": "vite build --config vite.config.js",
		"vue-build:ssr": "vite build --config vite.config.js && vite build --ssr --config vite.config.js",
		"prettier-format": "prettier --write resources/",
		"prettier-format:check": "prettier --check resources/",
		"eslint": "eslint . --fix",
		"eslint:check": "eslint .",
		"vue-types:check": "vue-tsc --noEmit",

		"mix": "mix",
		"mix-watch": "mix watch",
		"mix-watch-production": "mix --production -- --watch --progress",
		"mix-watch-poll": "mix watch -- --watch-options-poll=1000",
		"mix-watch-hot": "mix watch --hot",
		"mix-production": "mix --production",

		"blocks-build": "wp-scripts build --webpack-copy-php --blocks-manifest --source-path=./resources/views/blocks/src --output-path=./resources/views/blocks/build",
		"blocks-format": "wp-scripts format",
		"blocks-lint:css": "wp-scripts lint-style",
		"blocks-lint:js": "wp-scripts lint-js",
		"blocks-packages-update": "wp-scripts packages-update",
		"blocks-plugin-zip": "wp-scripts plugin-zip",
		"blocks-start": "wp-scripts start --webpack-copy-php --blocks-manifest --source-path=./resources/views/blocks/src --output-path=./resources/views/blocks/build"
	},
	"devDependencies": {
		"@eslint/js": "^9.19",
		"@laravel/vite-plugin-wayfinder": "^0.1",
		"@stylistic/eslint-plugin": "^5.10",
		"@tailwindcss/vite": "^4.0",
		"@types/jquery": "^4.0",
		"@types/jqueryui": "^1.12",
		"@types/node": "^22.13",
		"@vitejs/plugin-vue": "^6.0",
		"@vue/eslint-config-typescript": "^14.3",
		"@wordpress/scripts": "^31.8",
		"concurrently": "^9.2",
		"cross-env": "^10.1",
		"eslint": "^9.17",
		"eslint-config-prettier": "^10.0",
		"eslint-import-resolver-typescript": "^4.4",
		"eslint-plugin-import": "^2.32",
		"eslint-plugin-vue": "^9.32",
		"glob": "^13.0",
		"laravel-mix": "^6.0",
		"laravel-vite-plugin": "^3.0",
		"lodash": "^4.18",
		"mini-css-extract-plugin": "^2.10",
		"postcss": "^8.5",
		"prettier": "^3.4",
		"prettier-plugin-tailwindcss": "^0.6",
		"resolve-url-loader": "^5.0",
		"sass": "^1.99",
		"sass-loader": "^16.0",
		"tailwindcss": "^4.0",
		"ts-loader": "^9.5",
		"typescript": "^6.0",
		"typescript-eslint": "^8.23",
		"vite": "^8.0",
		"vue-tsc": "^2.2",
		"webpack": "~5.105.0",
		"webpack-remove-empty-scripts": "^1.1"
	},
	"dependencies": {
		"@inertiajs/vite": "^3.1",
		"@inertiajs/vue3": "^3.1",
		"@vue/server-renderer": "^3.5",
		"@vueuse/core": "^12.8",
		"class-variance-authority": "^0.7",
		"clsx": "^2.1",
		"laravel-vite-plugin": "^3.1",
		"lucide-vue-next": "^0.468",
		"reka-ui": "^2.6",
		"tailwind-merge": "^3.2",
		"tailwindcss": "^4.1",
		"tw-animate-css": "^1.2",
		"vue": "^3.5",
		"vue-input-otp": "^0.3",
		"vue-sonner": "^2.0"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-x64-gnu": "4.9",
		"@rollup/rollup-win32-x64-msvc": "4.9",
		"@tailwindcss/oxide-linux-x64-gnu": "^4.0",
		"@tailwindcss/oxide-win32-x64-msvc": "^4.0",
		"lightningcss-linux-x64-gnu": "^1.29",
		"lightningcss-win32-x64-msvc": "^1.29"
	}
}
